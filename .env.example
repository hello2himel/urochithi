# ============================================
# UROCHITHI - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values.
# These must also be set in Netlify: Site configuration → Environment variables

# ============================================
# REQUIRED
# ============================================

# Neon PostgreSQL connection string
# Get this from: Neon Console → Dashboard → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth URL (for Better Auth authentication)
# Get this from: Neon Console → Auth tab → Auth URL
NEON_AUTH_URL=https://your-project-id.auth.neon.tech
